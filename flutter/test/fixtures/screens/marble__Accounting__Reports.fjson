                  {
                    "_type": "container-row",
                    "columns": [
                      {
                        "lg": "",
                        "md": "6",
                        "sm": "",
                        "xs": "",
                        "style": "",
                        "children": [
                          {
                            "name": "OperatingRevenueExpenseChart",
                            "_type": "section-include",
                            "sectionName": "OperatingRevenueExpenseChart",
                            "widgets": [
                              {
                                "_type": "container-box",
                                "boxTitle": "Operating Revenue and Expense",
                                "header": [],
                                "toolbar": [
                                  {
                                    "_type": "text",
                                    "textType": "html,vuet,qvt",
                                    "location": "",
                                    "template": "true",
                                    "content": "<button type=\"button\" class=\"btn btn-primary btn-sm\" onclick=\"moqui.downloadData('${(revenueExpenseCsv!\"\")?js_string}', 'OperatingRevenueExpense.csv', 'text/csv')\">Get CSV</button>"
                                  }
                                ],
                                "body": [
                                  {
                                    "_type": "text",
                                    "textType": "html,vuet,qvt",
                                    "location": "",
                                    "template": "true",
                                    "content": "<div class=\"chart-container\" style=\"position:relative; height:400px; width:100%;\"><canvas id=\"RevenueExpenseChart\"></canvas></div>\n                <script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.3/Chart.min.js\" type=\"text/javascript\"></script>\n                <script>\n                var revenueExpenseChart = new Chart(document.getElementById(\"RevenueExpenseChart\"), {\n                    type: 'bar',\n                    data: { labels:${Static[\"groovy.json.JsonOutput\"].toJson(periodLabels!\"\")},\n                        datasets:${Static[\"groovy.json.JsonOutput\"].toJson(datasets!\"\")} },\n                    options: {\n                        scales:{ yAxes:[{ ticks:{ beginAtZero:true } }] }, maintainAspectRatio:false,\n                        tooltips:{ callbacks:{ label: function(tooltipItem, data) {\n                            var dataset = data.datasets[tooltipItem.datasetIndex];\n                            var datasetLabel = dataset.label || '';\n                            var curValue = dataset.data[tooltipItem.index];\n                            // NOTE: datasetIndex 0 is net revenue, the first dataset in the list\n                            if (tooltipItem.datasetIndex == 0) { return datasetLabel + \": \" + moqui.format(curValue, null, \"currency\"); }\n                            // calculate and show percent of net revenue for expenses\n                            var netRevenue = data.datasets[0].data[tooltipItem.index];\n                            var percentOfNet = netRevenue ? (curValue / netRevenue) * 100.0 : 0.0;\n                            return datasetLabel + \": \" + moqui.format(dataset.data[tooltipItem.index], null, \"currency\") + \" (\" + percentOfNet.toFixed(1) + \"% net)\";\n                        }}}\n                    }\n                });\n                </script>"
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "lg": "",
                        "md": "6",
                        "sm": "",
                        "xs": "",
                        "style": "",
                        "children": [
