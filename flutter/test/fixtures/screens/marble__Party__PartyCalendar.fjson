{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "PartyCalendar",
  "menuTitle": "Calendar",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "_type": "text",
          "textType": "html,vuet,qvt",
          "location": "",
          "template": "true",
          "content": "<div id=\"calendar\"></div>\n            <script src=\"https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/3.1.0/fullcalendar.min.js\" type=\"text/javascript\"></script>\n            <script src=\"https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/3.1.0/locale-all.js\" type=\"text/javascript\"></script>\n            <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/3.1.0/fullcalendar.min.css\" type=\"text/css\"/>\n            <script>\n    $('#calendar').fullCalendar({ timezone:false, defaultView:'agendaWeek', locale:'${ec.user.locale.toString()}',\n        header: { left:'prev,next today', center:'title', right:'month,agendaWeek,agendaDay' },\n        eventSources: [ { url:\"${sri.buildUrl('getCalendarEvents').url}\", type:'POST', data: { moquiSessionToken:'${ec.web.sessionToken}', partyId:'${partyId}' } },\n            { url:\"${sri.buildUrl('getCalendarTasks').url}\", type:'POST', data:{ moquiSessionToken:'${ec.web.sessionToken}', partyId:'${partyId}' }, backgroundColor:'#5cb85c', borderColor:'#4cae4c' } ]\n    });\n            </script>"
        }
      ]
    }
  ]
}