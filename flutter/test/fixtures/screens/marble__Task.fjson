                                      {
                                        "_type": "drop-down",
                                        "allow-empty": "true",
                                        "allowEmpty": "true",
                                        "allowMultiple": "false",
                                        "submitOnSelect": "false",
                                        "current": "selected",
                                        "showNot": "false",
                                        "options": [],
                                        "dynamicOptions": {
                                          "transition": "getTaskList",
                                          "serverSearch": "true",
                                          "minLength": "2",
                                          "dependsOnField": "rootWorkEffortId",
                                          "dependsOnParameter": ""
                                        }
                                      }
                                    ]
