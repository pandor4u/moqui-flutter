                                      {
                                        "_type": "drop-down",
                                        "allow-empty": "${allowEmpty ?: 'false'}",
                                        "no-current-selected-key": "${noCurrentSelectedKey?:''}",
                                        "style": "${style?:''}",
                                        "allow-multiple": "${allowMultiple ?: 'false'}",
                                        "show-not": "${showNot ?: 'false'}",
                                        "allowEmpty": "false",
                                        "allowMultiple": "false",
                                        "submitOnSelect": "false",
                                        "current": "selected",
                                        "showNot": "${showNot ?: 'false'}",
                                        "options": [
