                                        "allowEmpty": "true",
                                        "allowMultiple": "false",
                                        "submitOnSelect": "false",
                                        "current": "selected",
                                        "showNot": "false",
                                        "options": [],
                                        "dynamicOptions": {
                                          "transition": "getProjectMilestones",
                                          "serverSearch": "false",
                                          "minLength": "1",
                                          "dependsOnField": "rootWorkEffortId",
                                          "dependsOnParameter": ""
                                        }
                                      }
                                    ]
                                  },
                                  {
                                    "name": "parentWorkEffortId",
                                    "from": "",
                                    "hide": "",
                                    "align": "",
                                    "title": "Parent Task",
                                    "tooltip": "",
