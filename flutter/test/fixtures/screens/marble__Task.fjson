{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "Task",
  "menuTitle": "Tasks",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "type": "strong",
          "condition": "task != null",
          "_type": "label",
          "text": "Task ${task.workEffortId} - ${task.workEffortName}",
          "resolvedText": "Task ${task.workEffortId} - ${task.workEffortName}",
          "labelType": "strong",
          "encode": "true"
        },
        {
          "id": "task-panel",
          "type": "tab",
          "_type": "subscreens-panel",
          "menuType": "tab",
          "noMenu": "false",
          "subscreens": [
            {
              "name": "TaskSummary",
              "menuTitle": "Task Summary",
              "menuIndex": 0,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "EditTask",
              "menuTitle": "Task",
              "menuIndex": 1,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "EditTimeEntries",
              "menuTitle": "Time",
              "menuIndex": 1,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "EditUsers",
              "menuTitle": "Assignments",
              "menuIndex": 3,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "EditRelated",
              "menuTitle": "Related",
              "menuIndex": 4,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "EditRequests",
              "menuTitle": "Requests",
              "menuIndex": 5,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "EditWikiPages",
              "menuTitle": "Wiki Pages",
              "menuIndex": 6,
              "menuInclude": true,
              "disabled": false
            }
          ],
          "defaultItem": "FindTask",
          "activeSubscreen": {
            "_type": "screen",
            "renderMode": "fjson",
            "screenName": "FindTask",
            "widgets": [
              {
                "_type": "widgets",
                "children": [
                  {
                    "_type": "container-row",
                    "columns": [
                      {
                        "lg": "",
                        "md": "6",
                        "sm": "",
                        "xs": "",
                        "style": "",
                        "children": [
                          {
                            "name": "SearchOptions",
                            "_type": "form-single",
                            "formName": "SearchOptions",
                            "transition": "findTask",
                            "map": "fieldValues",
                            "fieldLayout": {
                              "_type": "field-layout",
                              "rows": [
                                {
                                  "_type": "field-row-big"
                                }
                              ]
                            },
                            "fields": [
                              {
                                "name": "queryString",
                                "from": "ec.web.parameters.queryString",
                                "hide": "",
                                "align": "",
                                "title": "Query String",
                                "tooltip": "",
                                "widgets": [
                                  {
                                    "_type": "text-line",
                                    "size": "40",
                                    "inputType": "text",
                                    "maxlength": "",
                                    "mask": "",
                                    "prefix": ""
                                  }
                                ]
                              },
                              {
                                "name": "submitButton",
                                "from": "",
                                "hide": "",
                                "align": "",
                                "title": "Text Search",
                                "tooltip": "",
                                "widgets": [
                                  {
                                    "_type": "submit",
                                    "text": "",
                                    "confirmation": "",
                                    "btnType": "",
                                    "icon": ""
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "lg": "",
                        "md": "6",
                        "sm": "",
                        "xs": "",
                        "style": "text-right",
                        "children": [
                          {
                            "id": "NewTaskContainer",
                            "_type": "container-dialog",
                            "buttonText": "New Task",
                            "dialogTitle": "",
                            "width": "",
                            "icon": "",
                            "btnType": "",
                            "children": [
                              {
                                "name": "NewTaskForm",
                                "_type": "form-single",
                                "formName": "NewTaskForm",
                                "transition": "createTask",
                                "map": "fieldValues",
                                "fields": [
                                  {
                                    "name": "rootWorkEffortId",
                                    "from": "",
                                    "hide": "",
                                    "align": "",
                                    "title": "Project",
                                    "tooltip": "",
                                    "widgets": [
                                      {
                                        "_type": "drop-down",
                                        "allow-empty": "true",
                                        "allowEmpty": "true",
                                        "allowMultiple": "false",
                                        "submitOnSelect": "false",
                                        "current": "selected",
                                        "showNot": "false",
                                        "options": [
                                          {
                                            "key": "100000",
                                            "text": "100000: Demo Test Project"
                                          },
                                          {
                                            "key": "100001",
                                            "text": "100001: Demo Test Project"
                                          },
                                          {
                                            "key": "100004",
                                            "text": "100004: Demo Test Project"
                                          },
                                          {
