{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "EditPrices",
  "menuTitle": "Prices",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "id": "NewPriceDialog",
          "_type": "container-dialog",
          "buttonText": "New Price",
          "dialogTitle": "",
          "width": "",
          "icon": "",
          "btnType": "",
          "children": [
            {
              "name": "NewPriceForm",
              "_type": "form-single",
              "formName": "NewPriceForm",
              "transition": "createProductPrice",
              "map": "fieldValues",
              "fields": [
                {
                  "name": "productId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Product",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "display-entity",
                      "entity-name": "mantle.product.Product",
                      "text": "${productName} [${pseudoId}]",
                      "entityName": "mantle.product.Product",
                      "keyFieldName": "",
                      "alsoHidden": "true",
                      "useCache": "true",
                      "defaultText": ""
                    }
                  ],
                  "currentValue": "DEMO_1_1"
                },
                {
                  "name": "priceTypeEnumId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Type",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "drop-down",
                      "allow-empty": "${allowEmpty ?: 'false'}",
                      "no-current-selected-key": "${noCurrentSelectedKey?:''}",
                      "style": "${style?:''}",
                      "allow-multiple": "${allowMultiple ?: 'false'}",
                      "show-not": "${showNot ?: 'false'}",
                      "allowEmpty": "false",
                      "allowMultiple": "false",
                      "submitOnSelect": "false",
                      "current": "selected",
                      "showNot": "${showNot ?: 'false'}",
                      "options": [
                        {
                          "key": "PptAverage",
                          "text": "Average Cost"
                        },
                        {
                          "key": "PptCompetitive",
                          "text": "Competitive Price"
                        },
                        {
                          "key": "PptCurrent",
                          "text": "Current Price"
                        },
                        {
                          "key": "PptList",
                          "text": "List Price"
                        },
                        {
                          "key": "PptMaximum",
                          "text": "Maximum Price"
                        },
                        {
                          "key": "PptMinimum",
                          "text": "Minimum Price"
                        },
                        {
                          "key": "PptPromotional",
                          "text": "Promotional Price"
                        },
                        {
                          "key": "PptSpecialPromo",
                          "text": "Special Promo Price"
                        },
                        {
                          "key": "PptWholesale",
                          "text": "Wholesale Price"
                        }
                      ]
                    }
                  ]
                },
                {
                  "name": "pricePurposeEnumId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Purpose",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "drop-down",
                      "allow-empty": "${allowEmpty ?: 'false'}",
                      "no-current-selected-key": "${noCurrentSelectedKey?:''}",
                      "style": "${style?:''}",
                      "allow-multiple": "${allowMultiple ?: 'false'}",
                      "show-not": "${showNot ?: 'false'}",
                      "allowEmpty": "false",
                      "allowMultiple": "false",
                      "submitOnSelect": "false",
                      "current": "selected",
                      "showNot": "${showNot ?: 'false'}",
                      "options": [
                        {
                          "key": "PppComponent",
                          "text": "Component Price"
                        },
                        {
                          "key": "PppPurchase",
                          "text": "Purchase/Initial"
                        },
                        {
                          "key": "PppRecurring",
                          "text": "Recurring Charge"
                        },
                        {
                          "key": "PppUsage",
                          "text": "Usage Charge"
                        }
                      ]
                    }
                  ]
                },
                {
                  "name": "vendorPartyId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Vendor",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "drop-down",
                      "allow-empty": "true",
                      "allowEmpty": "true",
                      "allowMultiple": "false",
                      "submitOnSelect": "false",
                      "current": "selected",
                      "showNot": "false",
                      "options": [],
                      "dynamicOptions": {
                        "transition": "searchPartyList",
                        "serverSearch": "true",
                        "minLength": "2"
                      }
                    }
                  ]
                },
                {
                  "name": "customerPartyId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Customer",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "drop-down",
                      "allow-empty": "true",
                      "allowEmpty": "true",
                      "allowMultiple": "false",
                      "submitOnSelect": "false",
                      "current": "selected",
                      "showNot": "false",
                      "options": [],
                      "dynamicOptions": {
                        "transition": "searchPartyList",
                        "serverSearch": "true",
                        "minLength": "2"
                      }
                    }
                  ]
                },
                {
                  "name": "otherPartyItemId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Other Party Product ID",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "text-line",
                      "size": "25",
                      "inputType": "text",
                      "maxlength": "",
                      "mask": "",
                      "prefix": ""
                    }
                  ]
                },
                {
                  "name": "fromDate",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "From Date",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "date-time",
                      "dateType": "timestamp",
                      "format": "",
                      "minuteStepping": ""
                    }
                  ]
                },
                {
                  "name": "thruDate",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Thru Date",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "date-time",
                      "dateType": "timestamp",
                      "format": "",
                      "minuteStepping": ""
                    }
                  ]
                },
                {
                  "name": "productStoreId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Store",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "drop-down",
                      "allow-empty": "true",
                      "allowEmpty": "true",
                      "allowMultiple": "false",
                      "submitOnSelect": "false",
                      "current": "selected",
                      "showNot": "false",
                      "options": [
                        {
                          "key": "POPC_DEFAULT",
                          "text": "Ziziwork Retail Store [POPC_DEFAULT]"
                        }
                      ]
                    }
                  ]
                },
                {
                  "name": "minQuantity",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Min Quantity",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "text-line",
                      "size": "10",
                      "default-value": "1",
                      "inputType": "text",
                      "maxlength": "",
                      "mask": "",
                      "prefix": ""
                    }
                  ]
                },
                {
                  "name": "price",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Price",
                  "tooltip": "",
