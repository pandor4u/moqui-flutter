                          "linkType": "auto",
                          "icon": "fa fa-download",
                          "badge": "",
                          "confirmation": "",
                          "tooltip": "",
                          "btnType": "",
                          "targetWindow": "",
                          "dynamicLoadId": "",
                          "parameterMap": {
                            "shipmentId": "100002"
                          },
                          "url": "/fapps/marble/Shipment/ShipmentDetail/ShipmentPack.pdf",
