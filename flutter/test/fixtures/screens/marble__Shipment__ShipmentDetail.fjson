{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "ShipmentDetail",
  "menuTitle": "Shipment",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "_type": "container-row",
          "columns": [
            {
              "lg": "",
              "md": "6",
              "sm": "",
              "xs": "",
              "style": "",
              "children": [
                {
                  "type": "h4",
                  "_type": "label",
                  "text": "Outgoing Shipment #100002",
                  "resolvedText": "Outgoing Shipment #100002",
                  "labelType": "h4",
                  "encode": "true"
                },
                {
                  "name": "ShipInputSection",
                  "condition": "shipment.statusId == 'ShipInput'",
                  "_type": "section",
                  "sectionName": "ShipInputSection",
                  "widgets": [
                    {
                      "name": "ShipInputInOutSection",
                      "condition": "isIncoming",
                      "_type": "section",
                      "sectionName": "ShipInputInOutSection",
                      "failWidgets": [
                        {
                          "_type": "link",
                          "urlType": "transition",
                          "text": "Set Scheduled",
                          "linkType": "auto",
                          "icon": "",
                          "badge": "",
                          "confirmation": "",
                          "tooltip": "",
                          "btnType": "success",
                          "targetWindow": "",
                          "dynamicLoadId": "",
                          "parameterMap": {
                            "shipmentId": "100002"
                          },
                          "url": "/fapps/marble/Shipment/ShipmentDetail/scheduleShipment",
                          "isAnchorLink": false
                        },
                        {
                          "_type": "link",
                          "urlType": "transition",
                          "text": "Set Picked",
                          "linkType": "auto",
                          "icon": "",
                          "badge": "",
                          "confirmation": "",
                          "tooltip": "",
                          "btnType": "",
                          "targetWindow": "",
                          "dynamicLoadId": "",
                          "parameterMap": {
                            "shipmentId": "100002"
                          },
                          "url": "/fapps/marble/Shipment/ShipmentDetail/pickShipment",
                          "isAnchorLink": false
                        }
                      ]
                    }
                  ]
                },
                {
                  "name": "ShipScheduledSection",
                  "condition": "shipment.statusId == 'ShipScheduled'",
                  "_type": "section",
                  "sectionName": "ShipScheduledSection"
                },
                {
                  "name": "PackShipmentSection",
                  "_type": "section-include",
                  "sectionName": "PackShipmentSection"
                },
                {
                  "name": "ShipShipmentSection",
                  "_type": "section-include",
                  "sectionName": "ShipShipmentSection"
                },
                {
                  "name": "DeliverShipmentSection",
                  "_type": "section-include",
                  "sectionName": "DeliverShipmentSection"
                },
                {
                  "name": "RequestLabelsSection",
                  "_type": "section-include",
                  "sectionName": "RequestLabelsSection"
                },
                {
                  "condition": "shippingGatewayConfigId && hasAnyLabels",
                  "_type": "link",
                  "urlType": "transition",
                  "text": "Track Labels",
                  "linkType": "auto",
                  "icon": "",
                  "badge": "",
                  "confirmation": "",
                  "tooltip": "",
                  "btnType": "",
                  "targetWindow": "",
                  "dynamicLoadId": "",
                  "parameterMap": {
                    "shipmentId": "100002"
                  },
                  "url": "/fapps/marble/Shipment/ShipmentDetail/trackShipmentLabels",
                  "isAnchorLink": false
                },
                {
                  "name": "PrintLabelsSection",
                  "_type": "section-include",
                  "sectionName": "PrintLabelsSection"
                },
                {
                  "name": "QzPrintLabelsSection",
                  "_type": "section-include",
                  "sectionName": "QzPrintLabelsSection"
                },
                {
                  "name": "ShipPackedSection",
                  "condition": "shipment.statusId == 'ShipPacked'",
                  "_type": "section",
                  "sectionName": "ShipPackedSection"
                },
                {
                  "name": "ShipShippedSection",
                  "condition": "shipment.statusId == 'ShipShipped'",
                  "_type": "section",
                  "sectionName": "ShipShippedSection"
                },
                {
                  "name": "ShipDeliveredSection",
                  "condition": "shipment.statusId == 'ShipDelivered'",
                  "_type": "section",
                  "sectionName": "ShipDeliveredSection"
                },
                {
                  "id": "CancelDialog",
                  "condition": "!(shipment.statusId in ['ShipDelivered', 'ShipRejected', 'ShipCancelled'])",
                  "_type": "container-dialog",
                  "buttonText": "Cancel Shipment",
                  "dialogTitle": "",
                  "width": "",
                  "icon": "",
                  "btnType": "",
                  "children": [
                    {
                      "condition": "isOutgoing && invoiceIdSet",
                      "type": "p",
                      "style": "text-danger",
                      "_type": "label",
                      "text": "Invoices associated with this shipment will be CANCELLED: ",
                      "resolvedText": "Invoices associated with this shipment will be CANCELLED: ",
                      "labelType": "p",
                      "encode": "true"
                    },
                    {
                      "condition": "!isOutgoing && invoiceIdSet",
                      "type": "p",
                      "style": "text-warning",
                      "_type": "label",
                      "text": "Invoices (found 0 associated with this shipment) will not be changed, must be cancelled manually",
                      "resolvedText": "Invoices (found 0 associated with this shipment) will not be changed, must be cancelled manually",
                      "labelType": "p",
                      "encode": "true"
                    },
                    {
                      "condition": "anyItemPacked",
                      "type": "p",
                      "style": "text-danger",
                      "_type": "label",
                      "text": "Items have been packed/issued, these will be un-packed and returned to inventory",
                      "resolvedText": "Items have been packed/issued, these will be un-packed and returned to inventory",
                      "labelType": "p",
                      "encode": "true"
                    },
                    {
                      "condition": "anyReceived",
                      "type": "p",
                      "style": "text-danger",
                      "_type": "label",
                      "text": "Items have been received, all receipt quantities will be set to zero",
                      "resolvedText": "Items have been received, all receipt quantities will be set to zero",
                      "labelType": "p",
                      "encode": "true"
                    },
                    {
                      "condition": "hasAnyLabels",
                      "type": "p",
                      "style": "text-warning",
                      "_type": "label",
                      "text": "Labels will not be refunded automatically, refund manually if needed",
                      "resolvedText": "Labels will not be refunded automatically, refund manually if needed",
                      "labelType": "p",
                      "encode": "true"
                    },
                    {
                      "type": "p",
                      "style": "text-warning",
                      "_type": "label",
                      "text": "Payments associated with this shipment through order or invoice will not be changed",
                      "resolvedText": "Payments associated with this shipment through order or invoice will not be changed",
                      "labelType": "p",
                      "encode": "true"
                    },
                    {
                      "type": "p",
                      "style": "text-danger",
                      "condition": "emailMessageCount",
                      "_type": "label",
                      "text": "Emails have been sent, these cannot be unsent",
                      "resolvedText": "Emails have been sent, these cannot be unsent",
                      "labelType": "p",
                      "encode": "true"
                    },
                    {
                      "_type": "label",
                      "text": "Are you sure you want to cancel this shipment?",
                      "resolvedText": "Are you sure you want to cancel this shipment?",
                      "labelType": "span",
                      "encode": "true"
                    },
                    {
                      "_type": "link",
                      "urlType": "transition",
                      "text": "Cancel Shipment",
                      "linkType": "auto",
                      "icon": "",
                      "badge": "",
                      "confirmation": "",
                      "tooltip": "",
                      "btnType": "",
                      "targetWindow": "",
                      "dynamicLoadId": "",
                      "parameterMap": {
                        "shipmentId": "100002"
                      },
                      "url": "/fapps/marble/Shipment/ShipmentDetail/cancelShipment",
                      "isAnchorLink": false
                    }
                  ]
                },
                {
                  "id": "AuditLogDialog",
                  "_type": "container-dialog",
                  "buttonText": "Audit Log",
                  "dialogTitle": "",
                  "width": "960",
                  "icon": "",
                  "btnType": "",
                  "children": [
                    {
                      "name": "AuditLogList",
                      "_type": "form-list",
                      "formName": "AuditLogList",
                      "transition": "",
                      "list": "auditLogList",
                      "paginate": "true",
                      "headerDialog": "",
                      "selectColumns": "",
                      "savedFinds": "",
                      "showCsvButton": "",
                      "showXlsxButton": "",
                      "showPageSize": "",
                      "skipForm": "true",
                      "headerFields": [],
                      "fields": [
                        {
                          "name": "changedDate",
                          "from": "",
                          "hide": "",
                          "align": "",
                          "title": "Date",
                          "tooltip": "",
                          "widgets": [
                            {
                              "_type": "display",
                              "alsoHidden": "true",
                              "encode": "true",
                              "format": "",
                              "currencyUnitField": ""
                            }
                          ]
                        },
                        {
                          "name": "changedByUserId",
                          "from": "",
                          "hide": "",
                          "align": "",
                          "title": "User",
                          "tooltip": "",
                          "widgets": [
                            {
                              "_type": "display-entity",
                              "text": "UsernameTemplate",
                              "entity-name": "mantle.party.PersonWithUserAccount",
                              "key-field-name": "userId",
                              "entityName": "mantle.party.PersonWithUserAccount",
                              "keyFieldName": "userId",
                              "alsoHidden": "true",
                              "useCache": "true",
                              "defaultText": ""
                            }
                          ]
                        },
                        {
                          "name": "pkSecondaryValue",
                          "from": "",
                          "hide": "",
                          "align": "",
                          "title": "Item",
                          "tooltip": "",
                          "widgets": [
                            {
                              "_type": "display",
                              "alsoHidden": "true",
                              "encode": "true",
                              "format": "",
                              "currencyUnitField": ""
                            }
                          ]
                        },
                        {
                          "name": "changedFieldName",
                          "from": "",
                          "hide": "",
                          "align": "",
                          "title": "Field",
                          "tooltip": "",
                          "widgets": [
                            {
                              "_type": "display",
                              "text": "${org.moqui.util.StringUtilities.camelCaseToPretty(changedFieldName)}",
                              "alsoHidden": "true",
                              "encode": "true",
                              "format": "",
                              "currencyUnitField": "",
                              "resolvedText": ""
                            }
                          ]
                        },
                        {
                          "name": "oldValueText",
                          "from": "",
                          "hide": "",
                          "align": "",
                          "title": "From",
                          "tooltip": "",
                          "widgets": [
                            {
                              "_type": "display",
                              "text": "${ec.entity.formatFieldString(changedEntityName, changedFieldName, oldValueText)}",
                              "alsoHidden": "true",
                              "encode": "true",
                              "format": "",
                              "currencyUnitField": "",
                              "resolvedText": ""
                            }
                          ]
                        },
                        {
                          "name": "newValueText",
                          "from": "",
                          "hide": "",
                          "align": "",
                          "title": "To",
                          "tooltip": "",
                          "widgets": [
                            {
                              "_type": "display",
                              "text": "${ec.entity.formatFieldString(changedEntityName, changedFieldName, newValueText)}",
                              "alsoHidden": "true",
                              "encode": "true",
                              "format": "",
                              "currencyUnitField": "",
                              "resolvedText": ""
                            }
                          ]
                        }
                      ],
                      "listData": []
                    }
                  ]
                },
                {
                  "_type": "container",
                  "containerType": "div",
                  "children": [
                    {
                      "name": "OutgoingTransferSection",
                      "condition": "isOutgoing || isTransfer",
                      "_type": "section",
                      "sectionName": "OutgoingTransferSection",
                      "widgets": [
                        {
                          "style": "${shipment.statusId in ['ShipScheduled', 'ShipPicked'] ? 'btn-info' : ''}",
                          "_type": "link",
                          "urlType": "transition",
                          "text": "Pick",
                          "linkType": "auto",
                          "icon": "fa fa-download",
                          "badge": "",
                          "confirmation": "",
                          "tooltip": "",
                          "btnType": "",
                          "targetWindow": "",
                          "dynamicLoadId": "",
                          "parameterMap": {
                            "shipmentId": "100002"
                          },
                          "url": "/fapps/marble/Shipment/ShipmentDetail/ShipmentPick.pdf",
                          "isAnchorLink": true
                        },
                        {
                          "_type": "text",
                          "textType": "vuet,qvt",
                          "location": "",
                          "template": "true",
                          "content": "<button v-if=\"$root.qzVue\" class=\"btn btn-default btn-sm\" onclick=\"moqui.printUrlMain('/fop/apps/${appRoot}/Shipment/ShipmentPick?shipmentId=${shipmentId}')\"><i class=\"fa fa-print\"></i> Pick</button>"
                        },
                        {
                          "style": "${shipment.statusId in ['ShipShipped', 'ShipPacked'] ? 'btn-info' : ''}",
                          "_type": "link",
                          "urlType": "transition",
