            {
              "name": "ShipmentItemsSection",
              "_type": "section-include",
              "sectionName": "ShipmentItemsSection",
              "widgets": [
                {
                  "type": "info",
                  "_type": "container-box",
                  "boxTitle": "${ec.resource.expand('ProductNameTemplate', '', sid)} (Qty ${ec.l10n.format(sid.quantity ?: 0, '#.##')})",
                  "header": [],
                  "toolbar": [
                    {
                      "name": "PackItemSection",
                      "condition": "allowPack",
                      "_type": "section",
                      "sectionName": "PackItemSection"
                    },
                    {
                      "name": "ReceiveItemSection",
                      "condition": "allowReceive",
                      "_type": "section",
                      "sectionName": "ReceiveItemSection"
                    }
                  ],
                  "body": [
                    {
                      "_type": "container-row",
                      "columns": [
                        {
                          "lg": "5",
                          "md": "",
                          "sm": "",
                          "xs": "",
                          "style": "",
                          "children": [
                            {
                              "condition": "isOutgoing || isTransfer",
                              "type": "div",
                              "_type": "label",
                              "text": "Packed/Issued: ${ec.l10n.format(sid.quantityTotal ?: 0, '#.##')}, Remaining: ${ec.l10n.format(quantityPackRemaining, '#.##')}  (Unit: ${productUom?.description ?: 'N/A'})",
                              "resolvedText": "Packed/Issued: ${ec.l10n.format(sid.quantityTotal ?: 0, '#.##')}, Remaining: ${ec.l10n.format(quantityPackRemaining, '#.##')}  (Unit: ${productUom?.description ?: 'N/A'})",
                              "labelType": "div",
                              "encode": "true"
                            },
                            {
                              "condition": "isIncoming || isTransfer",
