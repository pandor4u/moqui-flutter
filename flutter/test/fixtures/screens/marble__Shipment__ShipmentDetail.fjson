                    }
                  ]
                },
                {
                  "name": "PostalAddressOtherDestSection",
                  "condition": "isOutgoing || isTransfer",
                  "_type": "section",
                  "sectionName": "PostalAddressOtherDestSection",
                  "widgets": [
                    {
                      "_type": "container",
                      "containerType": "div",
                      "children": [
                        {
                          "id": "AddPostalInfoDest",
                          "condition": "allowUpdate || shipment.statusId == 'ShipPacked'",
                          "_type": "dynamic-dialog",
                          "dialogId": "AddPostalInfoDest",
                          "buttonText": "Add Dest. Address",
                          "transition": "UpdateContactInfo",
                          "dialogTitle": "",
                          "width": "800",
                          "height": "",
                          "icon": ""
                        }
                      ]
                    },
                    {
                      "style": "text-danger",
                      "type": "p",
                      "condition": "!lastRouteSegment.destPostalContactMechId",
                      "_type": "label",
                      "text": "No origin shipping address selected",
                      "resolvedText": "No origin shipping address selected",
                      "labelType": "p",
                      "encode": "true"
                    },
                    {
                      "style": "text-warning",
                      "type": "p",
                      "condition": "!firstRouteSegment.shipmentMethodEnumId",
                      "_type": "label",
                      "text": "No shipment method selected",
                      "resolvedText": "No shipment method selected",
                      "labelType": "p",
                      "encode": "true"
                    }
                  ]
                },
                {
                  "name": "ShippedShippingDestInfo",
                  "condition": "curDestPaInfo",
                  "_type": "section",
                  "sectionName": "ShippedShippingDestInfo"
                },
                {
                  "name": "PostalAddressOtherOriginSection",
                  "condition": "isIncoming",
                  "_type": "section",
                  "sectionName": "PostalAddressOtherOriginSection"
                },
                {
                  "name": "ShippedShippingOriginInfo",
                  "condition": "curOriginPaInfo",
                  "_type": "section",
                  "sectionName": "ShippedShippingOriginInfo"
                },
                {
                  "type": "dl",
                  "style": "dl-horizontal",
                  "_type": "container",
                  "containerType": "dl",
                  "children": [
                    {
                      "type": "dt",
                      "condition": "productStore != null",
                      "_type": "label",
                      "text": "Store",
                      "resolvedText": "Store",
                      "labelType": "dt",
                      "encode": "true"
                    },
                    {
                      "type": "dd",
                      "condition": "productStore != null",
                      "_type": "label",
                      "text": "${productStore.productStoreId}: ${productStore.storeName}",
                      "resolvedText": "${productStore.productStoreId}: ${productStore.storeName}",
                      "labelType": "dd",
                      "encode": "true"
                    },
                    {
                      "type": "dt",
                      "condition": "shippingGatewayConfig != null",
                      "_type": "label",
                      "text": "Shipping Gateway",
                      "resolvedText": "Shipping Gateway",
                      "labelType": "dt",
                      "encode": "true"
                    },
                    {
                      "type": "dd",
                      "condition": "shippingGatewayConfig != null",
                      "_type": "label",
                      "text": "${shippingGatewayConfig.description}",
                      "resolvedText": "${shippingGatewayConfig.description}",
                      "labelType": "dd",
                      "encode": "true"
                    },
                    {
                      "type": "dt",
                      "_type": "label",
                      "text": "Order Ship By",
                      "resolvedText": "Order Ship By",
                      "labelType": "dt",
                      "encode": "true"
                    },
                    {
                      "type": "dd",
                      "_type": "label",
                      "text": "N/A None",
                      "resolvedText": "N/A None",
                      "labelType": "dd",
                      "encode": "true"
                    }
                  ]
                },
                {
                  "name": "EditShipment",
                  "_type": "form-single",
                  "formName": "EditShipment",
                  "transition": "updateShipment",
                  "map": "shipment",
                  "fieldLayout": {
                    "_type": "field-layout",
                    "rows": [
                      {
                        "_type": "field-ref",
                        "name": "originPostalContactMechId"
                      },
                      {
                        "_type": "field-ref",
                        "name": "destPostalContactMechId"
                      },
                      {
                        "_type": "field-ref",
                        "name": "carrierAndShipmentMethod"
                      },
                      {
                        "_type": "field-row",
                        "fields": [
                          {
                            "name": "shipmentTypeEnumId"
                          },
                          {
                            "name": "statusId"
                          }
                        ]
                      },
                      {
                        "_type": "fields-not-referenced"
                      },
                      {
                        "_type": "field-row",
                        "fields": [
                          {
                            "name": "otherPartyOrderId"
                          },
                          {
                            "name": "signatureRequiredEnumId"
                          }
                        ]
                      },
                      {
                        "_type": "field-row",
                        "fields": [
                          {
                            "name": "shipAfterDate"
                          },
                          {
                            "name": "shipBeforeDate"
                          }
                        ]
                      },
                      {
                        "_type": "field-row",
                        "fields": [
                          {
                            "name": "estimatedReadyDate"
                          }
                        ]
                      },
                      {
                        "_type": "field-row",
                        "fields": [
                          {
                            "name": "estimatedShipDate"
                          },
                          {
                            "name": "estimatedArrivalDate"
                          }
                        ]
                      },
                      {
                        "_type": "field-row",
                        "fields": [
                          {
                            "name": "entryDate"
                          },
                          {
                            "name": "packedDate"
                          }
                        ]
                      },
                      {
                        "_type": "field-row",
                        "fields": [
                          {
                            "name": "actualStartDate"
                          },
                          {
                            "name": "actualArrivalDate"
                          }
                        ]
                      },
                      {
                        "_type": "field-ref",
                        "name": "submitButton"
                      }
                    ]
                  },
                  "fields": [
                    {
                      "name": "shipmentId",
                      "from": "",
                      "hide": "",
                      "align": "",
                      "title": "Shipment ID",
                      "tooltip": "",
                      "widgets": [
                        {
                          "_type": "hidden",
                          "defaultValue": ""
                        }
                      ],
                      "currentValue": "100002"
                    },
                    {
                      "name": "originPostalContactMechId",
                      "from": "firstRouteSegment.originPostalContactMechId",
                      "hide": "",
                      "align": "",
                      "title": "Origin Postal Contact Mech ID",
                      "tooltip": "",
                      "widgets": [
                        {
                          "_type": "hidden",
                          "defaultValue": ""
                        }
                      ]
                    },
                    {
                      "name": "destPostalContactMechId",
                      "from": "lastRouteSegment.destPostalContactMechId",
                      "hide": "",
                      "align": "",
                      "title": "Destination Address",
                      "tooltip": "",
                      "widgets": [
                        {
                          "_type": "drop-down",
                          "allow-empty": "true",
                          "allowEmpty": "true",
                          "allowMultiple": "false",
                          "submitOnSelect": "false",
                          "current": "selected",
                          "showNot": "false",
                          "options": [
                            {
                              "key": "CustJqpAddr",
                              "text": "Joe Q. Public - 1350 E. Flamingo Rd. #2345, Las Vegas, NV 89119-5263 USA 1-702-234-5678 - New"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "name": "carrierAndShipmentMethod",
                      "from": "",
                      "hide": "",
                      "align": "",
                      "title": "Ship By",
                      "tooltip": "",
                      "widgets": [
                        {
                          "_type": "drop-down",
