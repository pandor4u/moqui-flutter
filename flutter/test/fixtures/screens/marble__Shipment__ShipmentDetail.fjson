                          "location": "",
                          "template": "true",
                          "content": "<button v-if=\"$root.qzVue\" class=\"btn btn-default btn-sm\" onclick=\"moqui.printUrlMain('/fop/apps/${appRoot}/Shipment/ShipmentPack?shipmentId=${shipmentId}')\"><i class=\"fa fa-print\"></i> Pack</button>"
                        },
                        {
                          "style": "${shipment.statusId in ['ShipScheduled', 'ShipPicked'] ? 'btn-info' : ''}",
