                          "location": "",
                          "template": "true",
                          "content": "<button v-if=\"$root.qzVue\" class=\"btn btn-default btn-sm\" onclick=\"moqui.printUrlMain('/fop/apps/${appRoot}/Shipment/ShipmentByPackage?shipmentId=${shipmentId}')\"><i class=\"fa fa-print\"></i> Package</button>"
                        },
                        {
                          "style": "${shipment.statusId in ['ShipShipped', 'ShipPacked'] ? 'btn-info' : ''}",
