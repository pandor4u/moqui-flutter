                          "content": "<button v-if=\"$root.qzVue\" class=\"btn btn-default btn-sm\" onclick=\"moqui.printUrlMain('/fop/apps/${appRoot}/Shipment/ShipmentInsert?shipmentId=${shipmentId}')\"><i class=\"fa fa-print\"></i> Insert</button>"
                        }
                      ]
                    },
                    {
                      "name": "OrderLinks",
                      "_type": "section-iterate",
                      "sectionName": "OrderLinks",
                      "iterations": []
                    },
                    {
                      "name": "ReturnLinks",
                      "_type": "section-iterate",
                      "sectionName": "ReturnLinks",
                      "iterations": []
