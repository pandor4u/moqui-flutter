                    {
                      "key": "01",
                      "text": "01 "
                    }
                  ]
                }
              ]
            },
            {
              "name": "productCategoryId",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Category",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "drop-down",
                  "allow-empty": "true",
                  "allowEmpty": "true",
                  "allowMultiple": "false",
                  "submitOnSelect": "false",
                  "current": "selected",
                  "showNot": "false",
                  "options": [
                    {
                      "key": "PopcBrowseRoot",
                      "text": "Browse Root Category"
                    },
                    {
                      "key": "PopcDeals",
                      "text": "Deals"
                    },
                    {
                      "key": "DEMO_ONE",
