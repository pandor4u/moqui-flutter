{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "QuickItems",
  "menuTitle": "Quick Items",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "name": "QuickItemOptions",
          "_type": "form-single",
          "formName": "QuickItemOptions",
          "transition": ".",
