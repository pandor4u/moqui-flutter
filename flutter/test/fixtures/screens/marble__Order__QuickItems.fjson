            "rows": [
              {
                "_type": "field-row-big"
              },
              {
                "_type": "field-ref",
                "name": "orderId"
              },
              {
                "_type": "field-ref",
                "name": "orderByField"
              }
            ]
          },
          "fields": [
            {
              "name": "orderId",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Order ID",
              "tooltip": "",
