                    {
                      "_type": "link",
                      "urlType": "transition",
                      "text": "Clone",
                      "linkType": "auto",
                      "icon": "",
                      "badge": "",
                      "confirmation": "Create new order based on this one?",
                      "tooltip": "",
                      "btnType": "",
                      "targetWindow": "",
                      "dynamicLoadId": "",
                      "parameterMap": {
                        "orderId": "100006",
                        "baseOrderId": "100006"
                      },
                      "url": "/fapps/marble/Order/OrderDetail/cloneOrder",
                      "isAnchorLink": false,
                      "parameterFromFields": {
                        "baseOrderId": "orderId"
                      }
                    },
                    {
                      "id": "RecurDialog",
                      "type": "${orderHeader.recurCronExpression ? (orderHeader.statusId == 'OrderApproved' ? 'success' : 'warning') : 'primary'}",
                      "_type": "container-dialog",
                      "buttonText": "Recurring",
                      "dialogTitle": "",
                      "width": "",
                      "icon": "",
                      "btnType": "${orderHeader.recurCronExpression ? (orderHeader.statusId == 'OrderApproved' ? 'success' : 'warning') : 'primary'}",
                      "children": [
                        {
                          "type": "p",
                          "style": "text-warning",
                          "condition": "orderHeader.statusId != 'OrderApproved'",
                          "_type": "label",
                          "text": "Order is not in Approved status",
                          "resolvedText": "Order is not in Approved status",
                          "labelType": "p",
                          "encode": "true"
                        },
                        {
                          "type": "p",
                          "_type": "label",
                          "text": "Recurring orders in the Approved status will be automatically cloned according to the schedule and the clone will be automatically Placed. If there are no Approve Warnings the cloned order will be automatically Approved. If Auto Invoice is set to Y then if Approved will also create an Invoice for the Order.",
                          "resolvedText": "Recurring orders in the Approved status will be automatically cloned according to the schedule and the clone will be automatically Placed. If there are no Approve Warnings the cloned order will be automatically Approved. If Auto Invoice is set to Y then if Approved will also create an Invoice for the Order.",
                          "labelType": "p",
                          "encode": "true"
                        },
                        {
                          "name": "RecurOptions",
                          "_type": "form-single",
                          "formName": "RecurOptions",
                          "transition": "updateOrderRecur",
                          "map": "orderHeader",
                          "fields": [
                            {
                              "name": "orderId",
                              "from": "",
                              "hide": "",
                              "align": "",
                              "title": "Order ID",
                              "tooltip": "",
                              "widgets": [
                                {
                                  "_type": "hidden",
                                  "defaultValue": ""
                                }
                              ],
                              "currentValue": "100006"
                            },
                            {
                              "name": "recurCronExpression",
                              "from": "",
                              "hide": "",
                              "align": "",
                              "title": "Recur Schedule",
                              "tooltip": "",
                              "widgets": [
                                {
                                  "_type": "drop-down",
                                  "allow-empty": "true",
                                  "allowEmpty": "true",
                                  "allowMultiple": "false",
                                  "submitOnSelect": "false",
                                  "current": "selected",
                                  "showNot": "false",
                                  "options": [
                                    {
                                      "key": "null",
                                      "text": "Current: None"
                                    },
                                    {
                                      "key": "0 0 2 ? * MON",
                                      "text": "Weekly on Monday at 2 AM"
                                    },
                                    {
                                      "key": "0 0 2 1 * ?",
                                      "text": "Monthly on the 1st at 2 AM"
                                    },
                                    {
                                      "key": "0 0 2 15 * ?",
                                      "text": "Monthly on the 15th at 2 AM"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "name": "recurAutoInvoice",
                              "from": "",
                              "hide": "",
                              "align": "",
                              "title": "Auto Invoice",
                              "tooltip": "",
                              "widgets": [
                                {
                                  "_type": "radio",
                                  "no-current-selected-key": "N",
                                  "noCurrentSelectedKey": "N",
                                  "options": [
                                    {
                                      "key": "Y",
                                      "text": "Y"
                                    },
                                    {
                                      "key": "N",
                                      "text": "N"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "name": "lodInfo",
                              "from": "",
                              "hide": "",
                              "align": "",
                              "title": "Lod Info",
                              "tooltip": "",
                              "widgets": [
                                {
                                  "type": "p",
