                                  "text": "Last Ordered Date will be updated over time as recurring Order Clones are created.",
                                  "resolvedText": "Last Ordered Date will be updated over time as recurring Order Clones are created.",
                                  "labelType": "p",
                                  "encode": "true"
                                },
                                {
                                  "type": "p",
