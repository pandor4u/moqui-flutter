{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "OrderDetail",
  "menuTitle": "Order Detail",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "name": "OrderHeaderSection",
          "_type": "section",
          "sectionName": "OrderHeaderSection",
          "widgets": [
            {
              "_type": "container-row",
              "columns": [
                {
                  "lg": "6",
                  "md": "",
                  "sm": "",
                  "xs": "",
                  "style": "",
                  "children": [
                    {
                      "_type": "container-row",
                      "columns": [
                        {
                          "lg": "",
                          "md": "",
                          "sm": "6",
                          "xs": "",
                          "style": "",
                          "children": [
                            {
                              "type": "h4",
                              "_type": "label",
                              "text": "Order #100006",
                              "resolvedText": "Order #100006",
                              "labelType": "h4",
                              "encode": "true"
                            }
                          ]
                        },
                        {
                          "lg": "",
                          "md": "",
                          "sm": "6",
                          "xs": "",
                          "style": "",
                          "children": [
                            {
                              "condition": "orderHeader?.salesChannelEnumId == 'ScWeb'",
                              "type": "h4",
                              "style": "text-success",
                              "_type": "label",
                              "text": "Web Order (ecommerce)",
                              "resolvedText": "Web Order (ecommerce)",
                              "labelType": "h4",
                              "encode": "true"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "condition": "recurCronDescription",
                      "type": "h4",
                      "style": "text-success",
                      "_type": "label",
                      "text": "Recurring Order: null",
                      "resolvedText": "Recurring Order: null",
                      "labelType": "h4",
                      "encode": "true"
                    },
                    {
                      "name": "PlaceSection",
                      "condition": "orderHeader.statusId in ['OrderOpen', 'OrderProposed', 'OrderBeingChanged', 'OrderHold']",
                      "_type": "section",
                      "sectionName": "PlaceSection",
                      "widgets": [
                        {
                          "condition": "!placeWarnings",
                          "style": "btn-success",
                          "_type": "link",
                          "urlType": "transition",
                          "text": "Place",
                          "linkType": "hidden-form",
                          "icon": "",
                          "badge": "",
                          "confirmation": "",
                          "tooltip": "",
                          "btnType": "",
                          "targetWindow": "",
                          "dynamicLoadId": "",
                          "parameterMap": {
                            "orderId": "100006"
                          },
                          "url": "/fapps/marble/Order/OrderDetail/placeOrder",
                          "isAnchorLink": false
                        },
                        {
                          "id": "PlaceOrderDialog",
                          "condition": "placeWarnings",
                          "type": "success",
                          "_type": "container-dialog",
                          "buttonText": "Place Warnings",
                          "dialogTitle": "",
                          "width": "",
                          "icon": "",
                          "btnType": "success",
                          "children": [
                            {
                              "name": "PlaceWarningsSection",
                              "_type": "section-iterate",
                              "sectionName": "PlaceWarningsSection",
                              "iterations": [
                                [
                                  {
                                    "type": "p",
                                    "_type": "label",
                                    "text": "Order has no items",
                                    "resolvedText": "Order has no items",
                                    "labelType": "p",
                                    "encode": "true"
                                  }
                                ],
                                [
                                  {
                                    "type": "p",
                                    "_type": "label",
                                    "text": "Part 01 has no shipping address selected",
                                    "resolvedText": "Part 01 has no shipping address selected",
                                    "labelType": "p",
                                    "encode": "true"
                                  }
                                ],
                                [
                                  {
                                    "type": "p",
                                    "_type": "label",
                                    "text": "Part 01 has no shipment method selected",
                                    "resolvedText": "Part 01 has no shipment method selected",
                                    "labelType": "p",
                                    "encode": "true"
                                  }
                                ]
                              ]
                            },
                            {
                              "_type": "link",
                              "urlType": "transition",
                              "text": "Place Order Anyway",
                              "linkType": "hidden-form",
                              "icon": "",
                              "badge": "",
                              "confirmation": "",
                              "tooltip": "",
                              "btnType": "",
                              "targetWindow": "",
                              "dynamicLoadId": "",
                              "parameterMap": {
                                "orderId": "100006"
                              },
                              "url": "/fapps/marble/Order/OrderDetail/placeOrder",
                              "isAnchorLink": false
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "name": "ApproveSection",
                      "condition": "orderHeader.statusId in ['OrderPlaced', 'OrderProcessing', 'OrderHold']",
                      "_type": "section",
                      "sectionName": "ApproveSection"
                    },
                    {
                      "condition": "orderHeader.statusId == 'OrderApproved'",
                      "_type": "link",
                      "urlType": "transition",
                      "text": "Un-approve",
                      "linkType": "hidden-form",
                      "icon": "",
                      "badge": "",
                      "confirmation": "Un-approve order (change status back to Placed)?",
                      "tooltip": "",
                      "btnType": "",
                      "targetWindow": "",
                      "dynamicLoadId": "",
                      "parameterMap": {
                        "orderId": "100006"
                      },
                      "url": "/fapps/marble/Order/OrderDetail/placeOrder",
                      "isAnchorLink": false
                    },
                    {
                      "condition": "orderHeader.statusId == 'OrderApproved' && firstPartInfo.isCustomerInternalOrg",
                      "_type": "link",
                      "urlType": "transition",
                      "text": "Order Sent",
                      "linkType": "hidden-form",
                      "icon": "",
                      "badge": "",
                      "confirmation": "Mark order as Sent?",
                      "tooltip": "",
                      "btnType": "",
                      "targetWindow": "",
                      "dynamicLoadId": "",
                      "parameterMap": {
                        "orderId": "100006"
                      },
                      "url": "/fapps/marble/Order/OrderDetail/sendOrder",
                      "isAnchorLink": false
                    },
                    {
                      "condition": "orderHeader.statusId in ['OrderPlaced', 'OrderProcessing', 'OrderApproved']",
                      "_type": "link",
                      "urlType": "transition",
                      "text": "Hold",
                      "linkType": "hidden-form",
                      "icon": "",
                      "badge": "",
                      "confirmation": "Really hold order?",
                      "tooltip": "",
                      "btnType": "",
                      "targetWindow": "",
                      "dynamicLoadId": "",
                      "parameterMap": {
                        "orderId": "100006"
                      },
                      "url": "/fapps/marble/Order/OrderDetail/holdOrder",
                      "isAnchorLink": false
                    },
                    {
                      "condition": "orderHeader.statusId == 'OrderOpen'",
                      "_type": "link",
                      "urlType": "transition",
                      "text": "Quote Requested",
                      "linkType": "hidden-form",
                      "icon": "",
                      "badge": "",
                      "confirmation": "Set order as quote requested by customer?",
                      "tooltip": "",
                      "btnType": "",
                      "targetWindow": "",
                      "dynamicLoadId": "",
                      "parameterMap": {
                        "orderId": "100006"
                      },
                      "url": "/fapps/marble/Order/OrderDetail/requestOrder",
                      "isAnchorLink": false
                    },
                    {
                      "condition": "orderHeader.statusId in ['OrderOpen', 'OrderRequested']",
                      "_type": "link",
                      "urlType": "transition",
                      "text": "Propose Quote",
                      "linkType": "hidden-form",
                      "icon": "",
                      "badge": "",
                      "confirmation": "Propose quote to customer?",
                      "tooltip": "",
                      "btnType": "",
                      "targetWindow": "",
                      "dynamicLoadId": "",
                      "parameterMap": {
                        "orderId": "100006"
                      },
                      "url": "/fapps/marble/Order/OrderDetail/proposeOrder",
                      "isAnchorLink": false
                    },
                    {
                      "condition": "orderHeader.statusId == 'OrderRequested'",
                      "_type": "link",
                      "urlType": "transition",
                      "text": "Reject Quote Request",
                      "linkType": "hidden-form",
                      "icon": "",
                      "badge": "",
                      "confirmation": "Reject quote request and reject order?",
                      "tooltip": "",
                      "btnType": "",
                      "targetWindow": "",
                      "dynamicLoadId": "",
                      "parameterMap": {
                        "orderId": "100006"
                      },
                      "url": "/fapps/marble/Order/OrderDetail/rejectOrder",
                      "isAnchorLink": false
                    },
                    {
                      "id": "CloseOrderDialog",
                      "type": "warning",
                      "condition": "orderHeader.statusId in ['OrderOpen', 'OrderProposed', 'OrderPlaced', 'OrderProcessing', 'OrderApproved', 'OrderHold']",
