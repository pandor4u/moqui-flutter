                    "returnId": "100002"
                  },
                  "url": "/fapps/marble/Return/EditReturn/approveReturn",
                  "isAnchorLink": false
                },
                {
                  "condition": "returnHeader.statusId in ['ReturnCreated', 'ReturnRequested', 'ReturnApproved']",
                  "_type": "link",
                  "urlType": "transition",
                  "text": "Cancel",
                  "linkType": "auto",
                  "icon": "",
                  "badge": "",
