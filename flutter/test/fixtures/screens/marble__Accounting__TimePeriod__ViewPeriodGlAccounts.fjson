{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "ViewPeriodGlAccounts",
  "menuTitle": "Accounts",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "type": "h3",
          "_type": "label",
          "text": "Accounts for ZICORP FY2027 [100003]",
          "resolvedText": "Accounts for ZICORP FY2027 [100003]",
          "labelType": "h3",
          "encode": "true"
        },
        {
          "_type": "link",
          "urlType": "transition",
          "text": "Recalc All",
          "linkType": "auto",
          "icon": "",
          "badge": "",
          "confirmation": "",
          "tooltip": "",
          "btnType": "",
          "targetWindow": "",
          "dynamicLoadId": "",
          "parameterMap": {
            "timePeriodId": "100003",
            "organizationPartyId": "ORG_ZIZI_CORP"
          },
          "url": "/fapps/marble/Accounting/TimePeriod/ViewPeriodGlAccounts/recalculateAllAmounts",
          "isAnchorLink": false,
          "parameterFromFields": {
            "organizationPartyId": "timePeriod"
          }
        },
        {
          "name": "PeriodCloseSection",
          "condition": "timePeriod.isClosed == 'Y'",
          "_type": "section",
          "sectionName": "PeriodCloseSection",
          "failWidgets": [
