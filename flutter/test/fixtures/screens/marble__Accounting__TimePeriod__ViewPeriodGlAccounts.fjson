                "timePeriodId": "100003"
              },
              "url": "/fapps/marble/Accounting/TimePeriod/ViewPeriodGlAccounts/recalculateAmounts",
              "isAnchorLink": false,
              "parameterFromFields": {
                "timePeriodId": "timePeriodId"
              }
            },
            {
              "_type": "link",
              "urlType": "transition",
              "text": "Post Depreciation",
              "linkType": "auto",
              "icon": "",
              "badge": "",
              "confirmation": "",
              "tooltip": "",
              "btnType": "",
              "targetWindow": "",
              "dynamicLoadId": "",
              "parameterMap": {
                "timePeriodId": "100003"
              },
              "url": "/fapps/marble/Accounting/TimePeriod/ViewPeriodGlAccounts/postFaDepreciations",
              "isAnchorLink": false
            },
            {
              "_type": "link",
              "urlType": "transition",
              "text": "Close Period",
              "linkType": "auto",
              "icon": "",
              "badge": "",
              "confirmation": "Close period 100003: ZICORP FY2027?",
              "tooltip": "",
              "btnType": "",
              "targetWindow": "",
              "dynamicLoadId": "",
              "parameterMap": {
                "timePeriodId": "100003"
              },
              "url": "/fapps/marble/Accounting/TimePeriod/ViewPeriodGlAccounts/closePeriod",
              "isAnchorLink": false
            },
            {
              "_type": "link",
              "urlType": "transition",
              "text": "Close Period + Depends",
              "linkType": "auto",
              "icon": "",
              "badge": "",
              "confirmation": "Close period 100003: ZICORP FY2027 plus any previous or child periods that are not closed?",
              "tooltip": "",
              "btnType": "",
              "targetWindow": "",
              "dynamicLoadId": "",
              "parameterMap": {
                "timePeriodId": "100003",
                "closePrevious": "true",
                "closeChildren": "true"
              },
              "url": "/fapps/marble/Accounting/TimePeriod/ViewPeriodGlAccounts/closePeriod",
              "isAnchorLink": false
            }
          ]
        },
        {
          "id": "ClosingTransDialog",
          "_type": "container-dialog",
          "buttonText": "Net Income Closing Transactions",
          "dialogTitle": "",
          "width": "",
          "icon": "",
          "btnType": "",
          "children": [
            {
              "type": "p",
              "_type": "label",
              "text": "Creates a transaction for each income statement account class (Revenue, Cost of Sales, Expense, Non-Operating Income, Non-Operating Expense)",
              "resolvedText": "Creates a transaction for each income statement account class (Revenue, Cost of Sales, Expense, Non-Operating Income, Non-Operating Expense)",
              "labelType": "p",
              "encode": "true"
            },
            {
              "type": "p",
              "_type": "label",
              "text": "This can be run at any time, but best after a period is closed (Period Close type transactions may be posted after a period is closed)",
              "resolvedText": "This can be run at any time, but best after a period is closed (Period Close type transactions may be posted after a period is closed)",
              "labelType": "p",
              "encode": "true"
            },
            {
