                                    "lg": "",
                                    "md": "",
                                    "sm": "4",
                                    "xs": "",
                                    "style": "",
                                    "children": [
                                      {
                                        "type": "strong",
                                        "style": "${pstats.actualPlusRemainingOverEstimated ? 'text-danger' : 'text-success'}",
                                        "_type": "label",
                                        "text": "Worked 0 hrs",
                                        "resolvedText": "Worked 0 hrs",
                                        "labelType": "strong",
                                        "encode": "true"
                                      }
                                    ]
                                  },
                                  {
                                    "lg": "",
                                    "md": "",
                                    "sm": "4",
                                    "xs": "",
                                    "style": "",
                                    "children": [
                                      {
                                        "type": "strong",
                                        "style": "text-info",
                                        "_type": "label",
                                        "text": "Est Rem 8 hrs",
                                        "resolvedText": "Est Rem 8 hrs",
                                        "labelType": "strong",
                                        "encode": "true"
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "name": "TimeBudgetStats",
                                "condition": "project.totalTimeAllowed",
                                "_type": "section",
                                "sectionName": "TimeBudgetStats"
                              },
                              {
                                "_type": "container-row",
                                "columns": [
                                  {
                                    "lg": "",
                                    "md": "",
                                    "sm": "4",
                                    "xs": "",
                                    "style": "",
                                    "children": [
                                      {
                                        "type": "strong",
                                        "_type": "label",
                                        "text": "Avg Rate ",
                                        "resolvedText": "Avg Rate ",
                                        "labelType": "strong",
                                        "encode": "true"
                                      }
                                    ]
                                  },
                                  {
                                    "lg": "",
                                    "md": "",
                                    "sm": "4",
                                    "xs": "",
                                    "style": "",
                                    "children": [
                                      {
                                        "type": "strong",
                                        "style": "${pstats.clientActualOverBudget ? 'text-danger' : 'text-success'}",
                                        "_type": "label",
                                        "text": "Actual Cost ",
                                        "resolvedText": "Actual Cost ",
                                        "labelType": "strong",
                                        "encode": "true"
                                      }
                                    ]
                                  },
                                  {
                                    "lg": "",
                                    "md": "",
                                    "sm": "4",
                                    "xs": "",
                                    "style": "",
                                    "children": [
                                      {
                                        "type": "strong",
                                        "_type": "label",
                                        "text": "Est Cost ",
                                        "resolvedText": "Est Cost ",
                                        "labelType": "strong",
                                        "encode": "true"
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "name": "CostBudgetStats",
                                "condition": "project.totalClientCostAllowed",
                                "_type": "section",
                                "sectionName": "CostBudgetStats"
                              },
                              {
                                "_type": "container-row",
                                "columns": [
                                  {
                                    "lg": "",
                                    "md": "",
                                    "sm": "",
                                    "xs": "6",
                                    "style": "text-center",
                                    "children": [
                                      {
                                        "type": "strong",
                                        "_type": "label",
                                        "text": "Provider Cost ",
                                        "resolvedText": "Provider Cost ",
                                        "labelType": "strong",
                                        "encode": "true"
                                      }
                                    ]
                                  },
                                  {
                                    "lg": "",
                                    "md": "",
                                    "sm": "",
                                    "xs": "6",
                                    "style": "text-center",
                                    "children": [
                                      {
                                        "type": "strong",
                                        "_type": "label",
                                        "text": "Profit ",
                                        "resolvedText": "Profit ",
                                        "labelType": "strong",
                                        "encode": "true"
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
