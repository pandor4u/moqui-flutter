        {
          "_type": "container-row",
          "columns": [
            {
              "lg": "",
              "md": "6",
              "sm": "",
              "xs": "",
              "style": "",
              "children": [
                {
                  "name": "TaskTree",
                  "_type": "tree",
                  "treeName": "TaskTree",
                  "openPath": "",
                  "treeNodes": [
                    {
                      "name": "TaskNode",
                      "entryName": "",
                      "link": {
                        "id": "${treeNodeId == '#' ? '' : treeNodeId + '/'}${nodeList_entry.workEffortId}",
                        "_type": "link",
                        "urlType": "transition",
                        "text": "${nodeList_entry.workEffortId}: ${nodeList_entry.workEffortName} - ${nodeList_entry.statusDescription?:''}${nodeList_entry.priority ? ' - P ' + nodeList_entry.priority : ''}",
                        "linkType": "auto",
                        "icon": "",
                        "badge": "",
                        "confirmation": "",
                        "tooltip": "",
                        "btnType": "",
                        "targetWindow": "",
                        "dynamicLoadId": "",
                        "resolvedText": "${nodeList_entry.workEffortId}: ${nodeList_entry.workEffortName} - ${nodeList_entry.statusDescription?:''}${nodeList_entry.priority ? ' - P ' + nodeList_entry.priority : ''}",
                        "url": "taskSummary",
                        "isAnchorLink": false,
                        "parameters": [
                          {
                            "name": "workEffortId",
                            "value": "",
                            "from": "nodeList_entry.workEffortId"
                          }
                        ]
                      },
                      "subNodes": [
                        {
                          "nodeType": "TaskNode",
                          "list": "childTasks"
                        }
                      ]
                    }
                  ],
                  "items": []
                }
              ]
            },
