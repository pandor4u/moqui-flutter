{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "ProjectSummary",
  "menuTitle": "Project Summary",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "name": "ActiveProjectSection",
          "_type": "section-iterate",
          "sectionName": "ActiveProjectSection",
          "iterations": [
            [
              {
                "_type": "container-box",
                "header": [
                  {
                    "_type": "link",
                    "urlType": "transition",
                    "text": "100004",
                    "linkType": "anchor-button",
                    "icon": "",
                    "badge": "",
                    "confirmation": "",
                    "tooltip": "",
                    "btnType": "",
                    "targetWindow": "",
                    "dynamicLoadId": "",
                    "parameterMap": {
                      "workEffortId": "100004",
                      "rootWorkEffortId": "100004"
                    },
                    "url": "/fapps/marble/Project/ProjectSummary/projectSummary",
                    "isAnchorLink": true,
                    "parameterFromFields": {
                      "workEffortId": "project"
                    }
                  },
                  {
                    "type": "h5",
                    "_type": "label",
                    "text": "Demo Test Project",
                    "resolvedText": "Demo Test Project",
                    "labelType": "h5",
                    "encode": "true"
                  }
                ],
                "toolbar": [
                  {
                    "style": "label ${pstats.projectDanger ? 'label-danger' : (pstats.projectWarning ? 'label-warning' : 'label-success')}",
                    "_type": "label",
                    "text": "On Track",
                    "resolvedText": "On Track",
                    "labelType": "span",
                    "encode": "true"
                  }
                ],
                "body": [
                  {
                    "_type": "container-row",
                    "columns": [
                      {
                        "lg": "7",
                        "md": "",
                        "sm": "",
                        "xs": "",
                        "style": "",
                        "children": [
                          {
                            "style": "shaded-area",
                            "_type": "container",
                            "containerType": "div",
                            "children": [
                              {
                                "_type": "container-row",
                                "columns": [
                                  {
                                    "lg": "",
                                    "md": "",
                                    "sm": "2",
                                    "xs": "",
                                    "style": "",
                                    "children": [
                                      {
                                        "type": "strong",
                                        "_type": "label",
                                        "text": "Hrs Est",
                                        "resolvedText": "Hrs Est",
                                        "labelType": "strong",
                                        "encode": "true"
                                      }
                                    ]
                                  },
                                  {
                                    "lg": "",
                                    "md": "",
                                    "sm": "7",
                                    "xs": "",
                                    "style": "",
                                    "children": [
                                      {
                                        "_type": "text",
                                        "textType": "html,vuet",
                                        "location": "",
                                        "template": "true",
                                        "content": "<div class=\"progress middle\">\n                                <div class=\"progress-bar <#if pstats.actualPlusRemainingOverEstimated>progress-bar-danger<#else>progress-bar-success</#if>\" style=\"width: ${estimatedCompletePercentString}%;\" aria-valuenow=\"${estimatedCompletePercentString}\" aria-valuemin=\"0\" aria-valuemax=\"100\"></div>\n                                <div class=\"progress-bar progress-bar-info\" style=\"width: ${estimatedRemainingPercentString}%;\" aria-valuenow=\"${estimatedRemainingPercentString}\" aria-valuemin=\"0\" aria-valuemax=\"100\"></div>\n                            </div>"
                                      }
                                    ]
                                  },
                                  {
                                    "lg": "",
                                    "md": "",
                                    "sm": "3",
                                    "xs": "",
                                    "style": "",
                                    "children": [
                                      {
                                        "_type": "label",
                                        "text": "%",
                                        "resolvedText": "%",
                                        "labelType": "span",
                                        "encode": "true"
                                      },
                                      {
                                        "_type": "text",
                                        "textType": "html,vuet,qvt",
                                        "location": "",
                                        "template": "true",
                                        "content": "<i class=\"fa <#if pstats.actualPlusRemainingOverEstimated>fa-exclamation-circle text-danger<#else>fa-check-circle text-success</#if>\"></i>"
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "name": "TimeBudgetGraphs",
                                "condition": "project.totalTimeAllowed",
                                "_type": "section",
                                "sectionName": "TimeBudgetGraphs"
                              },
                              {
                                "name": "CostBudgetGraphs",
                                "condition": "project.totalClientCostAllowed",
                                "_type": "section",
                                "sectionName": "CostBudgetGraphs"
                              },
                              {
                                "_type": "container-row",
                                "columns": [
                                  {
                                    "lg": "",
                                    "md": "",
                                    "sm": "4",
                                    "xs": "",
                                    "style": "",
                                    "children": [
                                      {
                                        "type": "strong",
                                        "_type": "label",
                                        "text": "Estimate 8 hrs",
                                        "resolvedText": "Estimate 8 hrs",
                                        "labelType": "strong",
                                        "encode": "true"
                                      }
