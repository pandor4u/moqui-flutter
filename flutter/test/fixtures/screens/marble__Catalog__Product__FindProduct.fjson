{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "FindProduct",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "id": "NewProductDialog",
          "_type": "container-dialog",
          "buttonText": "New Product",
          "dialogTitle": "",
          "width": "",
          "icon": "",
          "btnType": "",
          "children": [
            {
              "name": "NewProductForm",
              "_type": "form-single",
              "formName": "NewProductForm",
              "transition": "createProduct",
              "map": "fieldValues",
              "fields": [
                {
                  "name": "productName",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Product Name",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "text-line",
                      "inputType": "text",
                      "size": "",
                      "maxlength": "",
                      "mask": "",
                      "prefix": ""
                    }
                  ]
                },
                {
                  "name": "productTypeEnumId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Product Type",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "drop-down",
                      "allow-empty": "${allowEmpty ?: 'false'}",
                      "no-current-selected-key": "${noCurrentSelectedKey?:''}",
                      "style": "${style?:''}",
                      "allow-multiple": "${allowMultiple ?: 'false'}",
                      "show-not": "${showNot ?: 'false'}",
                      "allowEmpty": "false",
                      "allowMultiple": "false",
                      "submitOnSelect": "false",
                      "current": "selected",
                      "showNot": "${showNot ?: 'false'}",
                      "options": [
                        {
                          "key": "PtAsset",
                          "text": "Asset (Good)"
                        },
                        {
                          "key": "PtAssetUse",
                          "text": "Asset Use"
                        },
                        {
                          "key": "PtConfigurable",
                          "text": "Configurable Good"
                        },
                        {
                          "key": "PtDigital",
                          "text": "Digital (download)"
                        },
                        {
                          "key": "PtDigitalAsset",
                          "text": "Digital and Asset"
                        },
                        {
                          "key": "PtFacilityUse",
                          "text": "Facility Use"
                        },
                        {
                          "key": "PtFinished",
                          "text": "Finished Good"
                        },
                        {
                          "key": "PtPickAssembly",
                          "text": "Pick Assembly"
                        },
                        {
                          "key": "PtService",
                          "text": "Service"
                        },
                        {
                          "key": "PtVirtual",
                          "text": "Virtual (with variants)"
                        }
                      ]
                    }
                  ]
                },
                {
                  "name": "ownerPartyId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Owned By Org",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "drop-down",
                      "allowEmpty": "true",
                      "allowMultiple": "false",
                      "submitOnSelect": "false",
                      "current": "selected",
                      "showNot": "false",
                      "options": [
                        {
                          "key": "_NA_",
                          "text": "N/A"
                        },
                        {
                          "key": "ORG_ZIZI_HR",
                          "text": "ZIHR: Ziziwork Human Resources"
                        },
                        {
                          "key": "ORG_ZIZI_CORP",
                          "text": "ZICORP: Ziziwork Industries"
                        },
                        {
                          "key": "ORG_ZIZI_RETAIL",
                          "text": "ZIRET: Ziziwork Retail & Wholesale"
                        },
                        {
                          "key": "ORG_ZIZI_SALES",
                          "text": "ZISAL: Ziziwork Sales"
                        },
                        {
                          "key": "ORG_ZIZI_SERVICES",
                          "text": "ZISER: Ziziwork Services"
                        }
                      ]
