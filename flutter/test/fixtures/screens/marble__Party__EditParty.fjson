                                            "isAnchorLink": false,
                                            "parameterFromFields": {
                                              "partyId": "partyId",
                                              "contactMechId": "contactInfo"
                                            }
                                          },
                                          {
                                            "condition": "!(contactInfo.postalContactMech.trustLevelEnumId in ['CmtlGreylisted', 'CmtlBlacklisted'])",
                                            "_type": "link",
                                            "urlType": "transition",
                                            "text": "Grey",
                                            "linkType": "auto",
                                            "icon": "",
                                            "badge": "",
                                            "confirmation": "Really greylist this address?",
                                            "tooltip": "",
                                            "btnType": "warning",
                                            "targetWindow": "",
                                            "dynamicLoadId": "",
                                            "parameterMap": {
                                              "trustLevelEnumId": "CmtlGreylisted",
                                              "partyId": "CustJqp",
                                              "contactMechId": "CustJqpAddr"
                                            },
                                            "url": "/fapps/marble/Party/EditParty/updateContactMechMutable",
                                            "isAnchorLink": false,
                                            "parameterFromFields": {
                                              "contactMechId": "contactInfo"
                                            }
                                          },
                                          {
                                            "condition": "contactInfo.postalContactMech.trustLevelEnumId != 'CmtlBlacklisted'",
                                            "_type": "link",
                                            "urlType": "transition",
                                            "text": "Black",
                                            "linkType": "auto",
                                            "icon": "",
                                            "badge": "",
                                            "confirmation": "Really blacklist this address?",
                                            "tooltip": "",
                                            "btnType": "danger",
                                            "targetWindow": "",
                                            "dynamicLoadId": "",
                                            "parameterMap": {
                                              "trustLevelEnumId": "CmtlBlacklisted",
                                              "partyId": "CustJqp",
                                              "contactMechId": "CustJqpAddr"
                                            },
                                            "url": "/fapps/marble/Party/EditParty/updateContactMechMutable",
                                            "isAnchorLink": false,
                                            "parameterFromFields": {
                                              "contactMechId": "contactInfo"
                                            }
                                          },
                                          {
                                            "condition": "contactInfo.postalContactMech.trustLevelEnumId in ['CmtlGreylisted', 'CmtlBlacklisted']",
