                                {
                                  "_type": "text-line",
                                  "size": "60",
                                  "default-value": "${party.firstName?:''}${party.middleName ? ' ' + party.middleName : ''}${party.lastName ? ' ' + party.lastName : ''}",
                                  "inputType": "text",
                                  "maxlength": "",
                                  "mask": "",
                                  "prefix": ""
                                }
                              ]
