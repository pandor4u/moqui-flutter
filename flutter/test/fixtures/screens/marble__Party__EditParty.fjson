                                            "text": "Trust: New",
                                            "resolvedText": "Trust: New",
                                            "labelType": "strong",
                                            "encode": "true"
                                          },
                                          {
                                            "condition": "!contactInfo.postalContactMech.trustLevelEnumId || contactInfo.postalContactMech.trustLevelEnumId == 'CmtlNew'",
                                            "_type": "link",
                                            "urlType": "transition",
                                            "text": "Validate",
                                            "linkType": "auto",
                                            "icon": "",
                                            "badge": "",
                                            "confirmation": "",
                                            "tooltip": "",
