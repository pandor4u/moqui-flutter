              "hide": "",
              "align": "",
              "title": "Update",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "submit",
                  "text": "",
                  "confirmation": "",
                  "btnType": "",
                  "icon": ""
                }
              ]
            },
            {
              "name": "postButton",
              "from": "",
              "hide": "",
              "align": "",
              "conditionalFields": [
                {
                  "condition": "isPosted != 'Y' && glJournalTypeEnumId != 'GLJRNL_ERROR'",
                  "conditionResult": true,
                  "title": "",
                  "widgets": [
                    {
                      "_type": "link",
                      "urlType": "transition",
                      "text": "Post##Accounting",
                      "linkType": "auto",
                      "icon": "",
                      "badge": "",
                      "confirmation": "",
                      "tooltip": "",
                      "btnType": "",
                      "targetWindow": "",
                      "dynamicLoadId": "",
                      "url": "/fapps/marble/Accounting/FindJournal/postGlJournal",
                      "isAnchorLink": false
                    }
                  ]
                }
              ],
              "title": "Post Button",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "link",
                  "urlType": "transition",
                  "text": "Post##Accounting",
                  "linkType": "auto",
                  "icon": "",
                  "badge": "",
                  "confirmation": "",
                  "tooltip": "",
                  "btnType": "",
                  "targetWindow": "",
                  "dynamicLoadId": "",
                  "url": "/fapps/marble/Accounting/FindJournal/postGlJournal",
