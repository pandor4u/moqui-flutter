              ]
            }
          ],
          "fields": [
            {
              "name": "glJournalId",
              "from": "",
              "hide": "",
              "align": "",
              "title": "ID",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "display",
                  "alsoHidden": "true",
                  "encode": "true",
                  "format": "",
                  "currencyUnitField": ""
                }
              ]
            },
            {
              "name": "glJournalName",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Journal Name",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "text-line",
                  "size": "30",
                  "inputType": "text",
                  "maxlength": "",
                  "mask": "",
                  "prefix": ""
                }
              ]
            },
            {
              "name": "organizationPartyId",
              "from": "",
              "hide": "",
