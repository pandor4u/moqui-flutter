            {
              "name": "submitButton",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Find",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "submit",
                  "text": "",
                  "confirmation": "",
                  "btnType": "",
                  "icon": ""
