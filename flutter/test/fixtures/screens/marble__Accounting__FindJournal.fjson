                  "_type": "link",
                  "urlType": "transition",
                  "text": "Transactions",
                  "linkType": "anchor-button",
                  "icon": "",
                  "badge": "",
                  "confirmation": "",
                  "tooltip": "",
                  "btnType": "",
                  "targetWindow": "",
                  "dynamicLoadId": "",
                  "parameterMap": {
                    "glJournalId": ""
                  },
                  "url": "/fapps/marble/Accounting/FindJournal/findTransaction",
                  "isAnchorLink": true,
                  "parameterFromFields": {
                    "glJournalId": "glJournalId"
                  }
                }
              ]
            }
          ],
          "listData": [
            {
              "glJournalId": "ORG_ZIZI_CORPError",
              "glJournalId_display": "ORG_ZIZI_CORPError",
              "glJournalName": "Error Journal for Ziziwork Industries",
              "organizationPartyId_display": "Ziziwork Industries  [ZICORP]",
