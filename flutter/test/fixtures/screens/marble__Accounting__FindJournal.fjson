              "title": "Organization",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "display-entity",
                  "entity-name": "mantle.party.PartyDetail",
                  "also-hidden": "false",
                  "key-field-name": "partyId",
                  "text": "${organizationName?:''}${firstName?:''} ${lastName?:''} [${pseudoId}]",
                  "entityName": "mantle.party.PartyDetail",
                  "keyFieldName": "partyId",
                  "alsoHidden": "false",
                  "useCache": "true",
                  "defaultText": ""
                }
              ]
            },
            {
              "name": "glJournalTypeEnumId",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Type",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "widget-template-include",
                  "location": "component://webroot/template/screen/BasicWidgetTemplates.xml#enumDropDown"
                }
              ]
            },
            {
              "name": "isPosted",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Posted",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "display",
                  "also-hidden": "false",
                  "alsoHidden": "false",
                  "encode": "true",
