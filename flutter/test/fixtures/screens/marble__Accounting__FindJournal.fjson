{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "FindJournal",
  "menuTitle": "GL Journals",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "id": "CreateTxDialog",
          "_type": "container-dialog",
          "buttonText": "New Journal",
          "dialogTitle": "",
          "width": "",
          "icon": "",
          "btnType": "",
          "children": [
            {
              "name": "CreateGlJournal",
              "_type": "form-single",
              "formName": "CreateGlJournal",
              "transition": "createGlJournal",
              "map": "fieldValues",
              "fields": [
                {
                  "name": "glJournalName",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Journal Name",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "text-line",
                      "size": "40",
                      "inputType": "text",
                      "maxlength": "",
                      "mask": "",
                      "prefix": ""
                    }
                  ]
                },
                {
                  "name": "glJournalTypeEnumId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Type",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "drop-down",
                      "allow-empty": "${allowEmpty ?: 'false'}",
                      "no-current-selected-key": "${noCurrentSelectedKey?:''}",
                      "style": "${style?:''}",
                      "allow-multiple": "${allowMultiple ?: 'false'}",
                      "show-not": "${showNot ?: 'false'}",
                      "allowEmpty": "false",
                      "allowMultiple": "false",
                      "submitOnSelect": "false",
                      "current": "selected",
                      "showNot": "${showNot ?: 'false'}",
                      "options": [
                        {
                          "key": "GLJRNL_ERROR",
                          "text": "Error Journal"
                        },
                        {
                          "key": "GLJRNL_MANUAL",
                          "text": "Manual Transactions Journal"
                        }
                      ]
                    }
                  ]
                },
                {
                  "name": "organizationPartyId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Organization",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "drop-down",
                      "allowEmpty": "true",
                      "allowMultiple": "false",
                      "submitOnSelect": "false",
                      "current": "selected",
                      "showNot": "false",
                      "options": [
                        {
                          "key": "ORG_ZIZI_HR",
                          "text": "Ziziwork Human Resources  [ZIHR]"
                        },
                        {
                          "key": "ORG_ZIZI_CORP",
                          "text": "Ziziwork Industries  [ZICORP]"
                        },
                        {
                          "key": "ORG_ZIZI_RETAIL",
                          "text": "Ziziwork Retail & Wholesale  [ZIRET]"
                        },
                        {
                          "key": "ORG_ZIZI_SALES",
                          "text": "Ziziwork Sales  [ZISAL]"
                        },
                        {
                          "key": "ORG_ZIZI_SERVICES",
                          "text": "Ziziwork Services  [ZISER]"
                        }
                      ]
                    }
                  ]
                },
                {
                  "name": "submitButton",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Create",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "submit",
                      "text": "",
                      "confirmation": "",
                      "btnType": "",
                      "icon": ""
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "name": "TransactionList",
          "_type": "form-list",
          "formName": "TransactionList",
          "transition": "updateGlJournal",
          "list": "glJournalList",
          "paginate": "true",
          "headerDialog": "true",
          "selectColumns": "true",
          "savedFinds": "true",
          "showCsvButton": "true",
          "showXlsxButton": "",
          "showPageSize": "",
          "skipForm": "",
          "editUrl": "findTransaction",
          "headerFields": [
            {
              "name": "glJournalId",
              "from": "",
              "hide": "",
              "align": "",
              "title": "ID",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "text-find",
                  "size": "10",
                  "hide-options": "true",
                  "maxlength": "",
                  "ignoreCase": "true",
                  "defaultOperator": "contains",
                  "hideOptions": "true"
                }
              ]
            },
            {
              "name": "glJournalName",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Journal Name",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "text-find",
                  "size": "20",
                  "hide-options": "true",
                  "maxlength": "",
                  "ignoreCase": "true",
                  "defaultOperator": "contains",
                  "hideOptions": "true"
                }
              ]
            },
            {
              "name": "organizationPartyId",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Organization",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "drop-down",
                  "allow-empty": "true",
                  "allowEmpty": "true",
                  "allowMultiple": "false",
                  "submitOnSelect": "false",
                  "current": "selected",
                  "showNot": "false",
                  "options": [
                    {
                      "key": "ORG_ZIZI_HR",
                      "text": "Ziziwork Human Resources   [ZIHR]"
                    },
                    {
                      "key": "ORG_ZIZI_CORP",
                      "text": "Ziziwork Industries   [ZICORP]"
                    },
                    {
                      "key": "ORG_ZIZI_RETAIL",
                      "text": "Ziziwork Retail & Wholesale   [ZIRET]"
                    },
                    {
                      "key": "ORG_ZIZI_SALES",
                      "text": "Ziziwork Sales   [ZISAL]"
                    },
                    {
                      "key": "ORG_ZIZI_SERVICES",
                      "text": "Ziziwork Services   [ZISER]"
                    }
                  ]
                }
              ]
            },
            {
              "name": "glJournalTypeEnumId",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Type",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "widget-template-include",
                  "location": "component://webroot/template/screen/BasicWidgetTemplates.xml#enumDropDown"
                }
              ]
            },
            {
              "name": "isPosted",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Posted",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "drop-down",
                  "allow-empty": "true",
                  "allowEmpty": "true",
                  "allowMultiple": "false",
                  "submitOnSelect": "false",
                  "current": "selected",
                  "showNot": "false",
                  "options": [
                    {
                      "key": "Y",
                      "text": "Y"
                    },
                    {
                      "key": "N",
                      "text": "N"
                    }
                  ]
                }
              ]
            },
            {
              "name": "postedDate",
              "from": "",
              "hide": "",
              "align": "",
              "title": "Posted Date",
              "tooltip": "",
              "widgets": [
                {
                  "_type": "date-period",
                  "allowEmpty": "true",
