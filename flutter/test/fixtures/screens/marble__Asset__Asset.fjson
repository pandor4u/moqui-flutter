{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "Asset",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "type": "strong",
          "condition": "asset",
          "_type": "label",
          "text": "AssetNameTemplate",
          "resolvedText": "AssetNameTemplate",
          "labelType": "strong",
          "encode": "true"
        },
        {
          "type": "strong",
          "condition": "product",
          "_type": "label",
          "text": ": ${product.productName}",
          "resolvedText": ": ${product.productName}",
          "labelType": "strong",
          "encode": "true"
        },
        {
          "id": "AssetPanel",
          "type": "tab",
          "_type": "subscreens-panel",
          "menuType": "tab",
          "noMenu": "false",
          "subscreens": [
            {
              "name": "AssetDetail",
              "menuTitle": "Asset Detail",
              "menuIndex": 1,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "DetailHistory",
              "menuTitle": "Detail History",
              "menuIndex": 2,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "MoveAsset",
              "menuTitle": "Move",
              "menuIndex": 3,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "AssetCalendar",
              "menuTitle": "Calendar",
              "menuIndex": 4,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "AssetMeters",
              "menuTitle": "Meter Readings",
              "menuIndex": 4,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "AssetMaintenance",
              "menuTitle": "Maintenance",
              "menuIndex": 5,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "AssetRegistrations",
              "menuTitle": "Registrations",
              "menuIndex": 6,
              "menuInclude": true,
              "disabled": false
            },
            {
              "name": "AssetParties",
              "menuTitle": "Assignments",
              "menuIndex": 8,
              "menuInclude": true,
              "disabled": false
            }
          ],
          "defaultItem": "FindSummary",
          "activeSubscreen": {
            "_type": "screen",
            "renderMode": "fjson",
            "screenName": "FindSummary",
            "widgets": [
              {
                "_type": "widgets",
                "children": [
                  {
                    "_type": "link",
                    "urlType": "transition",
                    "text": "Find Individual Assets",
