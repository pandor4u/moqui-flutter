{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "EditTimePeriod",
  "menuTitle": "Time Period",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "condition": "parentPeriod != null",
          "_type": "link",
          "urlType": "transition",
          "text": "Parent: ${parentPeriod.periodName}",
          "linkType": "auto",
          "icon": "",
          "badge": "",
          "confirmation": "",
          "tooltip": "",
          "btnType": "",
          "targetWindow": "",
          "dynamicLoadId": "",
          "resolvedText": "Parent: ${parentPeriod.periodName}",
          "url": "editTimePeriod",
          "isAnchorLink": false,
          "parameterFromFields": {
            "timePeriodId": "parentPeriod"
          }
        },
        {
          "condition": "previousPeriod != null",
          "_type": "link",
          "urlType": "transition",
          "text": "Previous: ZICORP FY2026",
          "linkType": "auto",
          "icon": "",
          "badge": "",
          "confirmation": "",
          "tooltip": "",
          "btnType": "",
          "targetWindow": "",
          "dynamicLoadId": "",
          "parameterMap": {
            "timePeriodId": "100000"
          },
          "url": "/fapps/marble/Accounting/TimePeriod/EditTimePeriod/editTimePeriod",
          "isAnchorLink": true,
          "parameterFromFields": {
            "timePeriodId": "previousPeriod"
          }
        },
        {
          "condition": "nextPeriod != null",
          "_type": "link",
          "urlType": "transition",
          "text": "Next: ${nextPeriod.periodName}",
          "linkType": "auto",
          "icon": "",
          "badge": "",
          "confirmation": "",
          "tooltip": "",
          "btnType": "",
          "targetWindow": "",
          "dynamicLoadId": "",
          "resolvedText": "Next: ${nextPeriod.periodName}",
          "url": "editTimePeriod",
          "isAnchorLink": false,
          "parameterFromFields": {
            "timePeriodId": "nextPeriod"
          }
        },
        {
          "id": "CreateNextDialog",
          "condition": "nextPeriod == null",
          "_type": "container-dialog",
          "buttonText": "Create Next Period",
          "dialogTitle": "",
          "width": "",
          "icon": "",
          "btnType": "",
          "children": [
            {
              "name": "CreateNextPeriod",
              "_type": "form-single",
              "formName": "CreateNextPeriod",
              "transition": "createNextTimePeriod",
              "map": "fieldValues",
              "fields": [
                {
                  "name": "previousPeriodId",
                  "from": "timePeriodId",
                  "hide": "",
                  "align": "",
                  "title": "Previous Period ID",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "hidden",
                      "defaultValue": ""
                    }
                  ],
                  "currentValue": "100003"
                },
                {
                  "name": "timePeriodTypeId",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Type",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "display",
                      "text": "${description}",
                      "text-map": "timePeriodType",
                      "alsoHidden": "true",
                      "encode": "true",
                      "format": "",
                      "currencyUnitField": "",
                      "resolvedText": "null"
                    }
                  ]
                },
                {
                  "name": "fromDate",
                  "from": "timePeriod.thruDate + 1",
                  "hide": "",
                  "align": "",
                  "title": "From Date",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "display",
                      "alsoHidden": "true",
                      "encode": "true",
                      "format": "",
                      "currencyUnitField": ""
                    }
                  ],
                  "currentValue": "2028-01-01"
                },
                {
                  "name": "thruDate",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Thru Date",
                  "tooltip": "Optional, leave empty to calculate with from date and period type",
                  "widgets": [
                    {
                      "_type": "date-time",
                      "type": "date",
                      "dateType": "date",
                      "format": "",
                      "minuteStepping": ""
                    }
                  ]
                },
                {
                  "name": "createBtn",
                  "from": "",
                  "hide": "",
                  "align": "",
                  "title": "Create",
                  "tooltip": "",
                  "widgets": [
                    {
                      "_type": "submit",
                      "text": "",
                      "confirmation": "",
                      "btnType": "",
                      "icon": ""
                    }
                  ]
                }
              ]
            }
          ]
