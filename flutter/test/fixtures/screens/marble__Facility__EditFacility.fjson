                  "urlType": "transition",
                  "text": "Validate Address",
                  "linkType": "auto",
                  "icon": "",
                  "badge": "",
                  "confirmation": "",
                  "tooltip": "",
                  "btnType": "",
                  "targetWindow": "",
                  "dynamicLoadId": "",
                  "parameterMap": {
                    "contactMechId": "ORG_ZIZI_RTL_SA",
                    "facilityId": "ZIRET_WH"
                  },
                  "url": "/fapps/marble/Facility/EditFacility/validateAddress",
                  "isAnchorLink": false,
                  "parameterFromFields": {
                    "facilityId": "facilityId",
                    "contactMechId": "contactInfo"
                  }
                },
                {
                  "name": "EditFacilityForm",
                  "_type": "form-single",
                  "formName": "EditFacilityForm",
                  "transition": "updateFacility",
