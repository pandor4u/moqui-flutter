{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "EditFacility",
  "menuTitle": "Facility",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "_type": "container-row",
          "columns": [
            {
              "lg": "7",
              "md": "",
              "sm": "",
              "xs": "",
              "style": "",
              "children": [
                {
                  "condition": "contactInfo.postalContactMech && (!contactInfo.postalContactMech.trustLevelEnumId || contactInfo.postalContactMech?.trustLevelEnumId == 'CmtlNew')",
