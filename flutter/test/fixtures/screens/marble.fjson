{
  "_type": "screen",
  "renderMode": "fjson",
  "screenName": "marble",
  "menuTitle": "Marble ERP",
  "widgets": [
    {
      "_type": "widgets",
      "children": [
        {
          "name": "OrgChooserSection",
          "condition": "hideNav != 'true'",
          "_type": "section",
          "sectionName": "OrgChooserSection",
          "widgets": [
            {
              "_type": "text",
              "textType": "html",
              "location": "",
              "template": "true",
              "content": "<div id=\"active-org-menu\" class=\"nav navbar-right dropdown\">\n                <a id=\"active-org-menu-link\" href=\"#\" class=\"dropdown-toggle btn btn-default btn-sm navbar-btn\" data-toggle=\"dropdown\" title=\"Organization\">\n                    <i class=\"fa fa-globe\"></i> ${(activeOrg.pseudoId)!}</a>\n                <ul class=\"dropdown-menu\">\n                    <#if activeOrg?has_content>\n                        <li><a href=\"${sri.buildUrl('/apps/setPrefGoLast').url}?preferenceKey=ACTIVE_ORGANIZATION&preferenceValue=\">Clear Active Organization</a></li>\n                    </#if>\n                    <#if userOrgList?has_content><#list userOrgList as userOrg>\n                        <li><a href=\"${sri.buildUrl('/apps/setPrefGoLast').url}?preferenceKey=ACTIVE_ORGANIZATION&preferenceValue=${userOrg.partyId}\">${userOrg.pseudoId}: ${userOrg.organizationName}</a></li>\n                    </#list></#if>\n                </ul>\n            </div>\n            <script>$(\"#navbar-buttons\").append($(\"#active-org-menu\")); $('#active-org-menu-link').tooltip({ placement:'bottom', trigger:'hover' });</script>"
            }
          ]
        },
        {
          "id": "MarbleErpPanel",
          "type": "popup",
          "title": "Marble ERP",
